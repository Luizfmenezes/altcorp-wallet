# Example environment variables
# Copy this file to .env.development or .env.production and adjust as needed

# API URL - Backend endpoint
# Development: http://localhost:8000/api/v1
# Production: /api/v1 (relative path for proxy)
VITE_API_URL=/api/v1

# Google OAuth Client ID (optional - for Google login)
VITE_GOOGLE_CLIENT_ID=
