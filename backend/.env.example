# =============================================================
# ALTCORP WALLET - Backend Environment Variables
# Copie este arquivo para .env e preencha os valores
# =============================================================

# ---- Banco de dados ----
DATABASE_URL=postgresql://walletuser:TROQUE_A_SENHA@database:5432/altcorp_wallet
POSTGRES_USER=walletuser
POSTGRES_PASSWORD=TROQUE_A_SENHA
POSTGRES_DB=altcorp_wallet

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False

# ---- Seguranca ----
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GERE_UMA_CHAVE_SECRETA_ALEATORIA_MIN_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- CORS ----
# Lista separada por virgula
# Inclui localhost, IP local 192.168.15.5:8080 e domínio de produção
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://192.168.15.5:8080,https://wallet.altcorphub.com

# ---- Email (Resend) ----
# Crie uma conta em https://resend.com e adicione seu dominio verificado
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=AltCorp Wallet <noreply@seudominio.com>

# ---- Google OAuth (opcional) ----
# Crie em https://console.cloud.google.com -> APIs -> Credenciais -> OAuth 2.0
GOOGLE_CLIENT_ID=

# ---- Groq API (IA - transcricao + LLM) ----
# https://console.groq.com/keys
GROQ_API_KEY=

# ---- Frontend (Build args para o Docker) ----
# Use caminho relativo para servir tanto em 192.168.15.5:8080 quanto em produção
VITE_API_URL=/api/v1
VITE_GOOGLE_CLIENT_ID=
