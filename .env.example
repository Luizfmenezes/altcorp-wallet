# =============================================================
# ALTCORP WALLET - Template de ambiente
# Copie para .env e preencha os valores reais
#
# Uso: docker compose up --build -d
# =============================================================

# ---- Banco de dados ----
POSTGRES_USER=walletuser
POSTGRES_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE
POSTGRES_DB=altcorp_wallet

# ---- Backend ----
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=TROQUE_POR_UMA_CHAVE_SECRETA_SEGURA
DEBUG=false
API_PORT=8000
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- Frontend (build args) ----
VITE_API_URL=/api/v1
VITE_GOOGLE_CLIENT_ID=

# ---- Google OAuth (backend redirect flow) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://wallet.altcorphub.com/api/v1/auth/google-callback
FRONTEND_URL=https://wallet.altcorphub.com

# ---- CORS ----
ALLOWED_ORIGINS=http://192.168.15.5:8080,https://wallet.altcorphub.com

# ---- Domínio ----
DOMAIN=wallet.altcorphub.com

# ---- Email (Resend) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=AltCorp Wallet <noreply@seudominio.com>

# ---- Groq AI ----
# https://console.groq.com/keys
GROQ_API_KEY=
