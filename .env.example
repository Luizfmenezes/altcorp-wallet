# ==============================================================================
# TEMPLATE DE CONFIGURAÇÃO — copie este arquivo para .env e preencha os valores
# NÃO coloque segredos reais aqui. Este arquivo VAI ao git.
# ==============================================================================

# ----------------------------
# Banco de Dados (PostgreSQL)
# ----------------------------
POSTGRES_USER=walletuser
POSTGRES_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE
POSTGRES_DB=altcorp_wallet

# ----------------------------
# Backend
# ----------------------------
# Gere uma chave aleatória: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=TROQUE_POR_UMA_CHAVE_SECRETA_DE_48_CHARS_MINIMO
DEBUG=False

# ----------------------------
# Portas (docker-compose)
# ----------------------------
API_PORT=8000
FRONTEND_PORT=8080

# ----------------------------
# CORS — origens permitidas (separadas por vírgula)
# Para produção: apenas o seu domínio
# Para dev local: adicione http://localhost:8080
# ----------------------------
ALLOWED_ORIGINS=https://seudominio.com,http://localhost:8080

# ----------------------------
# URL da API (usada no build do React)
# Para dev local use: /api/v1
# Para produção use: https://seudominio.com/api/v1
# ----------------------------
VITE_API_URL=/api/v1

API_PORT=8000# Leave empty for development mode (emails will be logged to console)

SENDGRID_API_KEY=

# ========================================FROM_EMAIL=noreply@altcorpwallet.com

# Frontend Configuration
# ========================================
FRONTEND_PORT=80

# ========================================
# CORS Configuration (Optional)
# ========================================
# Add your production domains separated by commas
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost
