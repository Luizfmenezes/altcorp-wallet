# =============================================================
# ALTCORP WALLET - Template de ambiente
# Copie para .env e preencha os valores reais
#
# DEV:  docker compose --profile dev up --build
# PROD: docker compose --profile prod up --build -d
# =============================================================

# ---- Banco de dados ----
POSTGRES_USER=walletuser
POSTGRES_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE
POSTGRES_DB=altcorp_wallet

# ---- Backend ----
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=TROQUE_POR_UMA_CHAVE_SECRETA_SEGURA
DEBUG=false
API_PORT=8000
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- Frontend ----
VITE_API_URL=/api/v1
VITE_GOOGLE_CLIENT_ID=

# ---- CORS ----
# Dev: incluir IP local. Prod: só o domínio.
ALLOWED_ORIGINS=http://192.168.15.5:8080,https://wallet.altcorphub.com

# ---- Domínio ----
DOMAIN=wallet.altcorphub.com

# ---- Email (Resend) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=AltCorp Wallet <noreply@altcorp.com.br>

# ---- Groq AI (gratuito) ----
# Obtenha em: https://console.groq.com/keys
# Tier gratuito: ~14.400 req/dia LLMs + Whisper ilimitado
GROQ_API_KEY=
